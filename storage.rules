rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function role() { return signedIn() && request.auth.token.role != null ? request.auth.token.role : 'Student'; }
    function staff() { return role() in ['Super Admin','Admin','Counselor','Sales Executive','Accounts']; }
    match /students/{studentId}/documents/{fileName} {
      allow read: if signedIn() && (staff() || request.auth.uid == studentId);
      allow create: if signedIn() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*|application/pdf');
      allow update, delete: if staff();
    }
  }
}
