    "test": "jest --runInBand"
  },
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.18.3",
    "express-rate-limit": "7.4.1",
    "firebase-admin": "12.7.0",
    "firebase-functions": "6.3.2",
    "helmet": "7.2.0",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "nodemailer": "6.9.16",
    "razorpay": "2.9.5",
    "stripe": "17.4.0",
    "swagger-ui-express": "5.0.1",
    "winston": "3.17.0",
    "xss": "1.0.15",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "typescript": "5.6.3"
  }
}
