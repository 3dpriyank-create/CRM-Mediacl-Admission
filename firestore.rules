rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function role() { return signedIn() ? get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role : null; }
    function admin() { return role() == 'superAdmin'; }
    function staff() { return role() in ['superAdmin','counselor','salesExecutive']; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }

    match /Users/{userId} { allow read: if owner(userId) || admin(); allow create, update, delete: if admin(); }
    match /Students/{studentId} { allow read: if staff() || owner(resource.data.userId) || owner(resource.data.parentUserId); allow write: if staff(); }
    match /Leads/{leadId} { allow read, create, update: if staff(); allow delete: if admin(); }
    match /Counselors/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /Colleges/{id} { allow read: if signedIn(); allow write: if staff(); }
    match /CounselingSessions/{id} { allow read: if staff() || owner(resource.data.studentUserId) || owner(resource.data.parentUserId); allow write: if staff(); }
    match /Documents/{id} { allow read: if staff() || owner(resource.data.studentUserId) || owner(resource.data.parentUserId); allow create: if signedIn(); allow update, delete: if staff() || owner(resource.data.studentUserId); }
    match /Payments/{id} { allow read: if staff() || owner(resource.data.studentUserId) || owner(resource.data.parentUserId); allow write: if staff(); }
    match /Tasks/{id} { allow read, write: if staff(); }
    match /Notifications/{id} { allow read: if staff() || owner(resource.data.userId); allow write: if staff(); }
    match /Reports/{id} { allow read, write: if admin(); }
    match /ActivityLogs/{id} { allow read: if admin(); allow create: if signedIn(); allow update, delete: if false; }
  }
}
